{
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "crons": [
    {
      "path": "/api/cron/feed",
      "schedule": "30 2 * * *"
    },
    {
      "path": "/api/cron/feed",
      "schedule": "30 13 * * *"
    }
  ]
}
