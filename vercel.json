{
  "buildCommand": "vite build",
  "outputDirectory": "dist/public",
  "installCommand": "npm install",
  "framework": null,
  "functions": {
    "api/index.ts": { "maxDuration": 60 }
  },
  "crons": [
    { "path": "/api/feed/refresh", "schedule": "30 2 * * *" },
    { "path": "/api/feed/refresh", "schedule": "30 8 * * *" },
    { "path": "/api/feed/refresh", "schedule": "30 13 * * *" },
    { "path": "/api/feed/refresh", "schedule": "30 18 * * *" }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
